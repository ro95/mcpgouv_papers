PORT=3001
NODE_ENV=development

# API Recherche d'entreprises (data.gouv.fr) - pas de clé requise
RECHERCHE_ENTREPRISES_BASE_URL=https://recherche-entreprises.api.gouv.fr

# Serveur MCP data.gouv.fr - pas de clé requise (accès public)
DATAGOUV_MCP_URL=https://mcp.data.gouv.fr/mcp

# CORS - URL du frontend Next.js
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────
# API Sirene INSEE — REQUIS pour le filtrage réel par date de création
# ──────────────────────────────────────────────────────────────────
# 1. https://portail-api.insee.fr → Applications → Souscriptions
# 2. Clique sur la ligne "API Sirene" → copie la valeur "Clés d'API"
# Sans cette clé : fallback sur l'API Recherche (sans filtrage date)
# ──────────────────────────────────────────────────────────────────
INSEE_API_KEY=

# ──────────────────────────────────────────────────────────────────
# API Pappers — enrichissement entreprises (site web, email, tel, CA)
# ──────────────────────────────────────────────────────────────────
# 1. https://www.pappers.fr/api → Créer un compte (gratuit, 100 crédits offerts)
# 2. Copier la clé API depuis le tableau de bord
# Sans cette clé : l'enrichissement Pappers est désactivé
# ──────────────────────────────────────────────────────────────────
PAPPERS_API_KEY=
PAPPERS_BASE_URL=https://api.pappers.fr/v2
